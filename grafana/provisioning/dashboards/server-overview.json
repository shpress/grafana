    {
      "id": 1,
      "title": "CPU Usage",
      "description": "CPU usage percentage across all servers",
      "type": "bargauge",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "100 - (avg by(server)(irate(node_cpu_seconds_total{mode=\"idle\", server=\"222\"}[5m])) * 100)",
          "legendFormat": "ZimaCube 222",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "100 - (avg by(server)(irate(node_cpu_seconds_total{mode=\"idle\", server=\"224\"}[5m])) * 100)",
          "legendFormat": "ZimaCube 224",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "100 - (avg by(server)(irate(node_cpu_seconds_total{mode=\"idle\", server=\"228\"}[5m])) * 100)",
          "legendFormat": "ZimaCube 228",
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "100 - (avg by(server)(irate(node_cpu_seconds_total{mode=\"idle\", server=\"46\"}[5m])) * 100)",
          "legendFormat": "Synology",
          "refId": "D",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "orange",
                "value": 85
              },
              {
                "color": "red",
                "value": 95
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "minVizHeight": 16,
        "minVizWidth": 8,
        "sizing": "auto",
        "valueMode": "text"
      }
    },
