{
  "uid": "storage",
  "title": "Storage",
  "description": "Storage monitoring across all servers: disk usage, I/O, and capacity predictions",
  "tags": ["storage", "disk", "infrastructure"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "5m",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "templating": {
    "list": [
      {
        "name": "server",
        "label": "Server",
        "type": "custom",
        "current": { "text": "All", "value": "$__all" },
        "options": [
          { "text": "All", "value": "$__all", "selected": true },
          { "text": "222", "value": "222", "selected": false },
          { "text": "224", "value": "224", "selected": false },
          { "text": "228", "value": "228", "selected": false },
          { "text": "46", "value": "46", "selected": false }
        ],
        "query": "222,224,228,46",
        "multi": true,
        "includeAll": true,
        "allValue": "222|224|228|46"
      },
      {
        "name": "show_network",
        "label": "Show Network Mounts",
        "type": "custom",
        "current": { "text": "No", "value": "no" },
        "options": [
          { "text": "No", "value": "no", "selected": true },
          { "text": "Yes", "value": "yes", "selected": false }
        ],
        "query": "no,yes",
        "multi": false,
        "includeAll": false
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Local Disk Usage by Server",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 10,
      "title": "ZimaCube 222",
      "description": "eMMC (44GB), SSD (477GB), HDD 8TB (7.3TB)",
      "type": "bargauge",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "(1 - node_filesystem_avail_bytes{server=\"222\",mountpoint=\"/DATA\"} / node_filesystem_size_bytes{server=\"222\",mountpoint=\"/DATA\"}) * 100",
          "legendFormat": "eMMC (/DATA)",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "(1 - node_filesystem_avail_bytes{server=\"222\",mountpoint=\"/media/sda\"} / node_filesystem_size_bytes{server=\"222\",mountpoint=\"/media/sda\"}) * 100",
          "legendFormat": "SSD (/media/sda)",
          "instant": true
        },
        {
          "refId": "C",
          "expr": "(1 - node_filesystem_avail_bytes{server=\"222\",mountpoint=\"/media/HDD-8TB\"} / node_filesystem_size_bytes{server=\"222\",mountpoint=\"/media/HDD-8TB\"}) * 100",
          "legendFormat": "HDD 8TB (/media/HDD-8TB)",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "orange", "value": 85 },
              { "color": "red", "value": 95 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "minVizHeight": 16,
        "minVizWidth": 8,
        "valueMode": "text"
      }
    },
