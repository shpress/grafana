    {
      "id": 102,
      "type": "row",
      "title": "Detailed Table",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "panels": []
    },
    {
      "id": 1,
      "title": "All Disks - Detailed View",
      "description": "All physical disks and volumes filtered to canonical mount points (duplicates removed)",
      "type": "table",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "custom": {
            "displayMode": "lcd-gauge",
            "inspectDetail": "header",
            "minWidth": 150,
            "align": "auto"
          },
          "min": 0,
          "max": 100
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Server" },
            "properties": [
              { "id": "custom.width", "value": 80 },
              { "id": "custom.displayMode", "value": "auto" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Mount Point" },
            "properties": [
              { "id": "custom.width", "value": 200 },
              { "id": "custom.displayMode", "value": "auto" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Device" },
            "properties": [
              { "id": "custom.width", "value": 200 },
              { "id": "custom.displayMode", "value": "auto" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Type" },
            "properties": [
              { "id": "custom.width", "value": 80 },
              { "id": "custom.displayMode", "value": "auto" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Total" },
            "properties": [
              { "id": "unit", "value": "bytes" },
              { "id": "custom.width", "value": 100 },
              { "id": "custom.displayMode", "value": "auto" },
              { "id": "decimals", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Available" },
            "properties": [
              { "id": "unit", "value": "bytes" },
              { "id": "custom.width", "value": 100 },
              { "id": "custom.displayMode", "value": "auto" },
              { "id": "decimals", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Used %" },
            "properties": [
              { "id": "custom.width", "value": 250 }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(1 - node_filesystem_avail_bytes{fstype!~\"tmpfs|devtmpfs|overlay|squashfs\",mountpoint!~\"/\\\\.|/var/|^/opt$|^/media$|/@\",server=~\"$server\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|devtmpfs|overlay|squashfs\",mountpoint!~\"/\\\\.|/var/|^/opt$|^/media$|/@\",server=~\"$server\"}) * 100",
          "legendFormat": "{{server}} - {{mountpoint}}",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "B",
          "expr": "node_filesystem_size_bytes{fstype!~\"tmpfs|devtmpfs|overlay|squashfs\",mountpoint!~\"/\\\\.|/var/|^/opt$|^/media$|/@\",server=~\"$server\"}",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "C",
          "expr": "node_filesystem_avail_bytes{fstype!~\"tmpfs|devtmpfs|overlay|squashfs\",mountpoint!~\"/\\\\.|/var/|^/opt$|^/media$|/@\",server=~\"$server\"}",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "mountpoint", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true, "Time 1": true, "Time 2": true, "Time 3": true,
              "__name__": true, "__name__ 1": true, "__name__ 2": true, "__name__ 3": true,
              "job": true, "job 1": true, "job 2": true, "job 3": true,
              "instance": true, "instance 1": true, "instance 2": true, "instance 3": true,
              "fstype 1": true, "fstype 2": true, "fstype 3": true,
              "device 1": true, "device 2": true, "device 3": true,
              "server 1": true, "server 2": true, "server 3": true,
              "mountpoint 1": true, "hostname": true, "hostname 1": true, "hostname 2": true, "hostname 3": true
            },
            "renameByName": {
              "server": "Server",
              "mountpoint": "Mount Point",
              "device": "Device",
              "fstype": "Type",
              "Value #A": "Used %",
              "Value #B": "Total",
              "Value #C": "Available"
            },
            "indexByName": {
              "Server": 0,
              "Mount Point": 1,
              "Device": 2,
              "Type": 3,
              "Total": 4,
              "Available": 5,
              "Used %": 6
            }
          }
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Used %", "desc": true }],
        "footer": { "show": false }
      }
    },
    {
      "id": 103,
      "type": "row",
      "title": "Disk I/O",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "panels": []
    },
    {
      "id": 4,
      "title": "Disk I/O - Read",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "decimals": 2,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "irate(node_disk_read_bytes_total{server=~\"$server\",device!~\"loop.*|dm-.*\"}[5m])",
          "legendFormat": "{{server}} - {{device}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 5,
      "title": "Disk I/O - Write",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "decimals": 2,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "irate(node_disk_written_bytes_total{server=~\"$server\",device!~\"loop.*|dm-.*\"}[5m])",
          "legendFormat": "{{server}} - {{device}}"
        }
